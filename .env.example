# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/flowgram?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption ────────────────────────────────────────────
AES_SECRET_KEY=32_char_secret_key_for_aes_256_enc

# ─── Redis (for BullMQ) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Flowgram <noreply@flowgram.io>

# ─── Meta / Instagram Graph API ────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Redirect URI registered in Meta Developer Console:
IG_OAUTH_REDIRECT_URI=https://your-backend.onrender.com/api/instagram/connect/callback
# Any random secret — used to verify webhook payloads from Meta:
IG_WEBHOOK_VERIFY_TOKEN=flowgram_webhook_2026
META_API_VERSION=v19.0

# ─── JazzCash (Pakistan Payments) ─────────────────────────
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_IS_SANDBOX=true
# Live: https://payments.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction
# Sandbox: https://sandbox.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction

# ─── EasyPaisa (Pakistan Payments) ────────────────────────
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_ACCOUNT_NUM=your_easypaisa_account_number
EASYPAISA_IS_SANDBOX=true
# Live: https://easypayportal.easypaisa.com.pk/tpg/
# Sandbox: https://easypaystg.easypaisa.com.pk/tpg/
EASYPAISA_API_URL=https://easypaystg.easypaisa.com.pk/tpg/

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
